rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && userProfile().data.status != 'suspended'
        && userProfile().data.role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superadmin');
    }

    function isSuperAdmin() {
      return hasRole('superadmin');
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /config/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /projects/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{document=**} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /inquiries/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if ownsUserDoc(userId) || isSuperAdmin();
      allow create: if ownsUserDoc(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ['user', 'admin', 'superadmin'];
      allow update: if ownsUserDoc(userId)
        || isSuperAdmin()
        || (isAdmin() && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
